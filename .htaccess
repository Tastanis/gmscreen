# Disable LiteSpeed Cache (common on cPanel hosts)
<IfModule LiteSpeed>
    CacheLookup off
</IfModule>

# Disable mod_cache if enabled
<IfModule mod_cache.c>
    CacheDisable /
</IfModule>

# Prevent caching of PHP/HTML pages
<FilesMatch "\.(php|html)$">
    <IfModule mod_headers.c>
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </IfModule>
</FilesMatch>

# Allow caching of static assets (images, CSS, JS) but with short lifetime
# so updates are picked up quickly
<FilesMatch "\.(css|js)$">
    <IfModule mod_headers.c>
        Header set Cache-Control "no-cache, must-revalidate"
    </IfModule>
</FilesMatch>
